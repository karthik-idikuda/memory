{
  "name": "neuronx-sdk",
  "version": "1.0.0",
  "description": "NEURON-X Omega TypeScript SDK — Self-Sovereign AI Memory",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "files": ["dist"],
  "scripts": {
